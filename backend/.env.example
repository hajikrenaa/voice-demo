OPENAI_API_KEY=sk-your-openai-api-key-here
ENVIRONMENT=development
LOG_LEVEL=INFO

# Vobiz Configuration
VOBIZ_AUTH_ID=your-vobiz-auth-id
VOBIZ_AUTH_TOKEN=your-vobiz-auth-token
VOBIZ_PHONE_NUMBER=+1234567890

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id

# ── Tamil language add-on (optional) ───────────────────────
# Tamil calls are selected per-call in the UI (Language: Tamil). These tune the Tamil
# voices; leave unset to use the defaults baked into config.py.
# Native Tamil ElevenLabs voice (defaults to "Meera"). Add it to your ElevenLabs
# workspace, or set your own Tamil voice ID here.
# ELEVENLABS_VOICE_ID_TA=gCr8TeSJgJaeaIoV4RWH
# OpenAI native (speech-to-speech) voice for Tamil; defaults to the English voice.
# Try "marin" or "cedar" for richer Tamil prosody (A/B test on real samples).
# REALTIME_VOICE_TA=marin
# Tamil input transcription. Defaults to whisper-1 (guaranteed compatible). For better
# Tamil accuracy, switch to gpt-4o-transcribe once a test call confirms it connects.
# TRANSCRIPTION_MODEL_TA=gpt-4o-transcribe

# Server URL (your public ngrok/server URL for Vobiz webhooks)
SERVER_URL=https://your-server.ngrok-free.app
