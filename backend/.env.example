OPENAI_API_KEY=sk-your-openai-api-key-here
ENVIRONMENT=development
LOG_LEVEL=INFO

# Vobiz Configuration
VOBIZ_AUTH_ID=your-vobiz-auth-id
VOBIZ_AUTH_TOKEN=your-vobiz-auth-token
VOBIZ_PHONE_NUMBER=+1234567890

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id

# Sarvam AI Configuration (3rd voice option — TTS only; STT/LLM stay on OpenAI)
SARVAM_API_KEY=your-sarvam-api-key
# Optional overrides (defaults baked into config.py):
# bulbul:v3 + ishita = Sarvam's recommended Tamil voice (default). For half the
# Sarvam cost use bulbul:v2 with a v2 speaker (anushka/manisha/vidya/arya/
# abhilash/karun/hitesh) — v2 and v3 speaker sets are NOT interchangeable.
# SARVAM_TTS_MODEL=bulbul:v3
# SARVAM_SPEAKER=ishita
# SARVAM_SPEAKER_TA=ishita

# ── Tamil language add-on (optional) ───────────────────────
# Tamil calls are selected per-call in the UI (Language: Tamil). These tune the Tamil
# voices; leave unset to use the defaults baked into config.py.
# Native Tamil ElevenLabs voice (defaults to "Meera"). Add it to your ElevenLabs
# workspace, or set your own Tamil voice ID here.
# ELEVENLABS_VOICE_ID_TA=gCr8TeSJgJaeaIoV4RWH
# OpenAI native (speech-to-speech) voice for Tamil; defaults to the English voice.
# Try "marin" or "cedar" for richer Tamil prosody (A/B test on real samples).
# REALTIME_VOICE_TA=marin
# Tamil input transcription defaults to gpt-4o-transcribe for better accuracy.
# TRANSCRIPTION_MODEL_TA=gpt-4o-transcribe

# Server URL (your public ngrok/server URL for Vobiz webhooks)
SERVER_URL=https://your-server.ngrok-free.app
# Production voice defaults (optional overrides)
REALTIME_MODEL=gpt-realtime-mini
REALTIME_VOICE=coral
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VAD_TYPE=server_vad
VAD_THRESHOLD=0.4
VAD_PREFIX_PADDING_MS=120
VAD_SILENCE_DURATION_MS=200
VAD_CREATE_RESPONSE=true
VAD_INTERRUPT_RESPONSE=false
INTERRUPTION_EVAL_DELAY_MS=250
BACKCHANNEL_MAX_DURATION_MS=250
VOBIZ_PLAYBACK_LAG_MS=80
PREWARM_TTL_S=75
REALTIME_HISTORY_TOKEN_LIMIT=8000
REALTIME_RETENTION_RATIO=0.8
CLOSE_CALL_ON_REALTIME_DISCONNECT=true